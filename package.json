{
  "name": "graphloupe",
  "displayName": "GraphLoupe",
  "description": "LangGraph execution-visualization / debugging IDE (VS Code Extension host).",
  "version": "0.2.0",
  "publisher": "byGao",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/byGao/GraphLoupe.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Debuggers",
    "Visualization",
    "AI"
  ],
  "keywords": [
    "langgraph",
    "langchain",
    "agent",
    "debugger",
    "graph",
    "visualization",
    "llm"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "graphloupe.open",
        "title": "GraphLoupe: Open Graph Panel"
      },
      {
        "command": "graphloupe.reload",
        "title": "GraphLoupe: Reload Graph"
      },
      {
        "command": "graphloupe.selectGraph",
        "title": "GraphLoupe: Select Graph"
      },
      {
        "command": "graphloupe.restartSidecar",
        "title": "GraphLoupe: Restart Sidecar"
      }
    ],
    "configuration": {
      "title": "GraphLoupe",
      "properties": {
        "graphloupe.graphEntry": {
          "type": "string",
          "default": "",
          "description": "Your graph entry as 'package.module:callable' (returns a compiled LangGraph), resolved against graphloupe.projectRoot. Empty = built-in demo graph. Loaded in an isolated worker subprocess."
        },
        "graphloupe.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Folder put on the worker's sys.path so graphEntry resolves against your project. Empty = the first workspace folder."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && npm run build",
    "render-docs": "node scripts/render-docs.mjs",
    "vscode:prepublish": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@vscode/vsce": "^3.2.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.0",
    "elkjs": "^0.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  }
}
