{
  "name": "graphloupe",
  "displayName": "GraphLoupe",
  "description": "LangGraph execution-visualization / debugging IDE (VS Code Extension host).",
  "version": "0.1.0",
  "publisher": "byGao",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "graphloupe.open",
        "title": "GraphLoupe: Open Graph Panel"
      },
      {
        "command": "graphloupe.reload",
        "title": "GraphLoupe: Reload Graph"
      },
      {
        "command": "graphloupe.selectGraph",
        "title": "GraphLoupe: Select Graph"
      }
    ],
    "configuration": {
      "title": "GraphLoupe",
      "properties": {
        "graphloupe.graphEntry": {
          "type": "string",
          "default": "",
          "description": "Your graph entry as 'package.module:callable' (returns a compiled LangGraph), resolved against graphloupe.projectRoot. Empty = built-in demo graph. Loaded in an isolated worker subprocess."
        },
        "graphloupe.projectRoot": {
          "type": "string",
          "default": "",
          "description": "Folder put on the worker's sys.path so graphEntry resolves against your project. Empty = the first workspace folder."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/vscode": "^1.90.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  }
}
